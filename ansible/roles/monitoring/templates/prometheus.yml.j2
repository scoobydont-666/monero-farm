global:
  scrape_interval: {{ prometheus_scrape_interval }}
  evaluation_interval: {{ prometheus_evaluation_interval }}

rule_files:
  - "/etc/prometheus/monerod_p2pool_alerts.yml"

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['127.0.0.1:9090']

  - job_name: 'node'
    static_configs:
      - targets: ['127.0.0.1:9100']

  - job_name: 'monero_p2pool_exporter'
    metrics_path: /metrics
    static_configs:
      - targets: ['127.0.0.1:{{ unified_exporter_port }}']

  - job_name: 'p2pool_observer_exporter'
    static_configs:
      - targets: ['127.0.0.1:{{ observer_exporter_port }}']

  {# plan-approved: ansible-role-edit (plans/2026-05-10-monero-farm-hygiene.md, Group B Codex P3 — use monero_zmq_port var) #}
  # B1 — ZMQ TCP heartbeat probe (blackbox_exporter tcp_connect module)
  - job_name: 'monerod_zmq_probe'
    metrics_path: /probe
    params:
      module: [tcp_connect]
    static_configs:
      - targets: ['127.0.0.1:{{ monero_zmq_port | default(18083) }}']
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: '127.0.0.1:{{ blackbox_exporter_port | default(9115) }}'

{% if prometheus_remote_targets is defined %}
  # Remote fleet targets
{% for target in prometheus_remote_targets %}
  - job_name: '{{ target.name }}'
    static_configs:
      - targets: ['{{ target.host }}:{{ target.port }}']
        labels:
          host: {{ target.label }}
{% endfor %}
{% endif %}
