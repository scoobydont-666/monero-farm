groups:
- name: monerod-p2pool
  rules:

  - alert: MonerodDown
    expr: up{job="monerod"} == 0
    for: 30s
    labels:
      severity: critical
    annotations:
      summary: "Monerod is DOWN"
      description: "Prometheus cannot scrape the monerod exporter on {{ '{{' }} $labels.instance {{ '}}' }}."

  - alert: MonerodNotSyncing
    expr: (monerod_target_height - monerod_height) > 5000
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: "Monerod is too far behind"
      description: "Target height is {{ '{{' }} $value {{ '}}' }} blocks ahead. Node is not syncing fast enough."

  - alert: MonerodZeroPeers
    expr: (monerod_outgoing_connections_count + monerod_incoming_connections_count) == 0
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: "Monerod has no peers"
      description: "Node is running but has no peers for more than 5 minutes."

  - alert: P2PoolExporterDown
    expr: up{job="monero_p2pool_exporter"} == 0
    for: 30s
    labels:
      severity: critical
    annotations:
      summary: "Unified XMR Exporter is down"
      description: "Prometheus cannot scrape the unified exporter on {{ '{{' }} $labels.instance {{ '}}' }}."

  - alert: P2PoolNoStratumConnections
    expr: p2pool_stratum_connections == 0
    for: 15m
    labels:
      severity: warning
    annotations:
      summary: "No miners connected to P2Pool"
      description: "Sidechain={{ '{{' }} $labels.sidechain {{ '}}' }} has no miners for 15 minutes."

  - alert: P2PoolLowHashrate
    expr: p2pool_stratum_hashrate_15m < 10000
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: "Very low P2Pool hashrate"
      description: "Hashrate on sidechain {{ '{{' }} $labels.sidechain {{ '}}' }} dropped below 10 kH/s."

  - alert: P2PoolNoBlocksFoundRecently
    expr: (time() - p2pool_pool_last_block_found_timestamp) > (24 * 3600)
    for: 1h
    labels:
      severity: info
    annotations:
      summary: "P2Pool has not found a block in 24 hours"
      description: "Sidechain {{ '{{' }} $labels.sidechain {{ '}}' }} block time seems unusually long."

  - alert: HighCPULoad
    expr: (1 - avg(rate(node_cpu_seconds_total{mode="idle"}[3m]))) > 0.9
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: "High CPU Load"
      description: "CPU load has exceeded 90% for 10 minutes."

  - alert: LowDiskSpace
    expr: (node_filesystem_avail_bytes{mountpoint="/"} / node_filesystem_size_bytes{mountpoint="/"}) < 0.05
    for: 10m
    labels:
      severity: critical
    annotations:
      summary: "Low disk space"
      description: "Disk has less than 5% remaining."

  - alert: HighRAMUsage
    expr: (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) > 0.90
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: "High RAM usage"
      description: "Machine RAM usage exceeded 90%."

  # B1 — ZMQ heartbeat: P2Pool uses ZMQ for block notifications; silent death = deaf relay
  - alert: MonerodZmqDown
    expr: probe_success{job="monerod_zmq_probe"} == 0
    for: 2m
    labels:
      severity: critical
    annotations:
      summary: "Monerod ZMQ port 18083 is unreachable"
      description: "TCP probe to 127.0.0.1:18083 failed for 2 minutes. P2Pool will not receive new block notifications."

  # B2 — P2Pool share staleness: 0 shares for 24h = sidechain fork or monerod desync
  - alert: P2PoolNoSharesFor24h
    expr: |
      (
        (time() - p2pool_local_stratum_last_share_timestamp{chain="mini"}) > 86400
        or
        (time() - p2pool_local_stratum_last_share_timestamp{chain="main"}) > 86400
      )
    for: 30m
    labels:
      severity: warning
    annotations:
      summary: "P2Pool sidechain {{ '{{' }} $labels.chain {{ '}}' }} has had no shares for 24h"
      description: "Last share timestamp is more than 24 hours old. Possible sidechain fork, monerod desync, or no miners connected."

  # B3 — monerod reorg depth: get_alternate_chains; >3 unexpected competing blocks
  - alert: MonerodDeepReorg
    expr: monero_alternate_chains > 3
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: "Monerod has {{ '{{' }} $value {{ '}}' }} alternate chains (possible reorg)"
      description: "get_alternate_chains returned more than 3 entries. Investigate with monerod get_alternate_chains RPC."
