{
  "uid": "monero-p2pool-unified",
  "title": "Monero P2Pool Unified",
  "tags": ["monero", "p2pool", "mining"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {"from": "now-6h", "to": "now"},
  "templating": {"list": []},
  "panels": [
    {"type": "row", "title": "Monero Network", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}, "collapsed": false, "id": 100, "panels": []},
    {"type": "stat", "id": 1, "title": "Block Height", "gridPos": {"h": 3, "w": 4, "x": 0, "y": 1}, "fieldConfig": {"defaults": {"unit": "none", "decimals": 0, "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}]}}}, "targets": [{"expr": "monero_height", "refId": "A"}], "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "textMode": "value"}},
    {"type": "stat", "id": 2, "title": "Sync Status", "gridPos": {"h": 3, "w": 3, "x": 4, "y": 1}, "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"1": {"text": "SYNCED", "color": "green"}, "0": {"text": "SYNCING", "color": "yellow"}}}], "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "yellow", "value": null}, {"color": "green", "value": 1}]}}}, "targets": [{"expr": "monero_synchronized", "refId": "A"}], "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "textMode": "value"}},
    {"type": "stat", "id": 3, "title": "Peers Out / In", "gridPos": {"h": 3, "w": 3, "x": 7, "y": 1}, "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 1}, {"color": "green", "value": 8}]}}}, "targets": [{"expr": "monero_outgoing_connections", "legendFormat": "out", "refId": "A"}, {"expr": "monero_incoming_connections", "legendFormat": "in", "refId": "B"}], "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "textMode": "value_and_name"}},
    {"type": "stat", "id": 4, "title": "Network Difficulty", "gridPos": {"h": 3, "w": 4, "x": 10, "y": 1}, "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "blue", "value": null}]}}}, "targets": [{"expr": "monero_difficulty", "refId": "A"}], "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"}},
    {"type": "stat", "id": 5, "title": "Block Reward", "gridPos": {"h": 3, "w": 3, "x": 14, "y": 1}, "fieldConfig": {"defaults": {"unit": "none", "decimals": 4, "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "orange", "value": null}]}}}, "targets": [{"expr": "monero_last_block_reward / 1e12", "legendFormat": "XMR", "refId": "A"}], "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"}},
    {"type": "stat", "id": 6, "title": "Mempool", "gridPos": {"h": 3, "w": 3, "x": 17, "y": 1}, "fieldConfig": {"defaults": {"unit": "none", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 50}, {"color": "red", "value": 200}]}}}, "targets": [{"expr": "monero_txpool_txs_total", "legendFormat": "txs", "refId": "A"}], "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"}},
    {"type": "stat", "id": 7, "title": "DB Size", "gridPos": {"h": 3, "w": 4, "x": 20, "y": 1}, "fieldConfig": {"defaults": {"unit": "decbytes", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "blue", "value": null}]}}}, "targets": [{"expr": "monero_database_size_bytes", "refId": "A"}], "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"}},

    {"type": "row", "title": "P2Pool Sidechains", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 4}, "collapsed": false, "id": 101, "panels": []},
    {"type": "stat", "id": 10, "title": "Mini Sidechain", "gridPos": {"h": 4, "w": 4, "x": 0, "y": 5}, "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "purple", "value": null}]}}}, "targets": [{"expr": "p2pool_mini_hashrate", "legendFormat": "Hashrate H/s", "refId": "A"}, {"expr": "p2pool_mini_miners", "legendFormat": "Miners", "refId": "B"}], "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "textMode": "value_and_name"}},
    {"type": "stat", "id": 11, "title": "Main Sidechain", "gridPos": {"h": 4, "w": 4, "x": 4, "y": 5}, "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "blue", "value": null}]}}}, "targets": [{"expr": "p2pool_main_hashrate", "legendFormat": "Hashrate H/s", "refId": "A"}, {"expr": "p2pool_main_miners", "legendFormat": "Miners", "refId": "B"}], "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "textMode": "value_and_name"}},
    {"type": "stat", "id": 12, "title": "Local Stratum Miners", "gridPos": {"h": 4, "w": 4, "x": 8, "y": 5}, "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}}}, "targets": [{"expr": "p2pool_local_stratum_connections", "legendFormat": "connected", "refId": "A"}], "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "textMode": "value"}},
    {"type": "stat", "id": 13, "title": "Shares Found", "gridPos": {"h": 4, "w": 4, "x": 12, "y": 5}, "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}]}}}, "targets": [{"expr": "p2pool_local_stratum_shares_found", "legendFormat": "found", "refId": "A"}, {"expr": "p2pool_local_stratum_shares_failed", "legendFormat": "failed", "refId": "B"}], "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "textMode": "value_and_name"}},
    {"type": "stat", "id": 14, "title": "Block Reward Share %", "gridPos": {"h": 4, "w": 4, "x": 16, "y": 5}, "fieldConfig": {"defaults": {"unit": "percent", "decimals": 6, "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "orange", "value": null}]}}}, "targets": [{"expr": "p2pool_local_stratum_block_reward_share_percent", "refId": "A"}], "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"}},
    {"type": "stat", "id": 15, "title": "Last Payout", "gridPos": {"h": 4, "w": 4, "x": 20, "y": 5}, "fieldConfig": {"defaults": {"unit": "none", "decimals": 6, "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}]}}}, "targets": [{"expr": "p2pool_mini_last_payout_reward_xmr", "legendFormat": "XMR", "refId": "A"}], "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "textMode": "value_and_name"}},

    {"type": "row", "title": "Hashrate & Performance", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9}, "collapsed": false, "id": 102, "panels": []},
    {"type": "timeseries", "id": 20, "title": "Local Stratum Hashrate", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10}, "fieldConfig": {"defaults": {"unit": "Hs", "custom": {"lineWidth": 2, "fillOpacity": 15, "gradientMode": "scheme", "showPoints": "never"}}}, "targets": [{"expr": "p2pool_local_stratum_hashrate_15m", "legendFormat": "15m", "refId": "A"}, {"expr": "p2pool_local_stratum_hashrate_1h", "legendFormat": "1h", "refId": "B"}, {"expr": "p2pool_local_stratum_hashrate_24h", "legendFormat": "24h", "refId": "C"}]},
    {"type": "timeseries", "id": 21, "title": "Mining Effort %", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10}, "fieldConfig": {"defaults": {"unit": "percent", "custom": {"lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "thresholdsStyle": {"mode": "line"}}, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 100}, {"color": "red", "value": 300}]}}}, "targets": [{"expr": "p2pool_local_stratum_current_effort", "legendFormat": "current", "refId": "A"}, {"expr": "p2pool_local_stratum_average_effort", "legendFormat": "average", "refId": "B"}]},
    {"type": "timeseries", "id": 22, "title": "Global Sidechain Hashrate", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 18}, "fieldConfig": {"defaults": {"unit": "Hs", "custom": {"lineWidth": 2, "fillOpacity": 10, "gradientMode": "scheme", "showPoints": "never"}}}, "targets": [{"expr": "p2pool_mini_hashrate", "legendFormat": "mini global", "refId": "A"}, {"expr": "p2pool_main_hashrate", "legendFormat": "main global", "refId": "B"}, {"expr": "p2pool_pool_stats_pool_statistics_hashrate", "legendFormat": "local pool", "refId": "C"}]},
    {"type": "timeseries", "id": 23, "title": "P2Pool Connections", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 18}, "fieldConfig": {"defaults": {"custom": {"lineWidth": 2, "fillOpacity": 10, "showPoints": "never"}}}, "targets": [{"expr": "p2pool_local_p2p_connections", "legendFormat": "P2P peers", "refId": "A"}, {"expr": "p2pool_local_stratum_connections", "legendFormat": "stratum miners", "refId": "B"}, {"expr": "p2pool_local_p2p_peer_list_size", "legendFormat": "peer list", "refId": "C"}]},

    {"type": "row", "title": "PPLNS Window & Payouts", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 26}, "collapsed": false, "id": 103, "panels": []},
    {"type": "timeseries", "id": 30, "title": "PPLNS Window Shares", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 27}, "fieldConfig": {"defaults": {"custom": {"lineWidth": 2, "fillOpacity": 20, "gradientMode": "scheme", "showPoints": "never"}, "color": {"mode": "palette-classic"}}}, "targets": [{"expr": "p2pool_mini_miner_window_shares{window_index=\"1\"}", "legendFormat": "shares (current)", "refId": "A"}, {"expr": "p2pool_mini_miner_window_uncles{window_index=\"1\"}", "legendFormat": "uncles (current)", "refId": "B"}]},
    {"type": "timeseries", "id": 31, "title": "Shares Found Rate", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 27}, "fieldConfig": {"defaults": {"custom": {"lineWidth": 2, "fillOpacity": 10, "showPoints": "never"}}}, "targets": [{"expr": "increase(p2pool_local_stratum_shares_found[1h])", "legendFormat": "found/hr", "refId": "A"}, {"expr": "increase(p2pool_local_stratum_shares_failed[1h])", "legendFormat": "failed/hr", "refId": "B"}]},
    {"type": "stat", "id": 32, "title": "Since Last Payout", "gridPos": {"h": 4, "w": 6, "x": 0, "y": 35}, "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 3600}, {"color": "red", "value": 86400}]}}}, "targets": [{"expr": "time() - p2pool_mini_last_payout_timestamp", "refId": "A"}], "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"}},
    {"type": "stat", "id": 33, "title": "Payout Height", "gridPos": {"h": 4, "w": 6, "x": 6, "y": 35}, "fieldConfig": {"defaults": {"unit": "none", "decimals": 0, "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "blue", "value": null}]}}}, "targets": [{"expr": "p2pool_mini_last_payout_main_height", "legendFormat": "main chain", "refId": "A"}], "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"}},
    {"type": "stat", "id": 34, "title": "PPLNS Window Size", "gridPos": {"h": 4, "w": 6, "x": 12, "y": 35}, "fieldConfig": {"defaults": {"unit": "none", "decimals": 0, "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "purple", "value": null}]}}}, "targets": [{"expr": "p2pool_pool_stats_pool_statistics_pplnswindowsize", "refId": "A"}], "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"}},
    {"type": "stat", "id": 35, "title": "Sidechain Difficulty", "gridPos": {"h": 4, "w": 6, "x": 18, "y": 35}, "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "blue", "value": null}]}}}, "targets": [{"expr": "p2pool_pool_stats_pool_statistics_sidechaindifficulty", "refId": "A"}], "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"}},

    {"type": "row", "title": "System Health", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 39}, "collapsed": false, "id": 104, "panels": []},
    {"type": "timeseries", "id": 40, "title": "CPU Usage", "gridPos": {"h": 7, "w": 8, "x": 0, "y": 40}, "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1, "custom": {"lineWidth": 2, "fillOpacity": 20, "gradientMode": "scheme", "showPoints": "never"}, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.8}, {"color": "red", "value": 0.95}]}}}, "targets": [{"expr": "1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[3m]))", "legendFormat": "CPU", "refId": "A"}]},
    {"type": "timeseries", "id": 41, "title": "Memory Usage", "gridPos": {"h": 7, "w": 8, "x": 8, "y": 40}, "fieldConfig": {"defaults": {"unit": "decbytes", "custom": {"lineWidth": 2, "fillOpacity": 20, "gradientMode": "scheme", "showPoints": "never"}}}, "targets": [{"expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes", "legendFormat": "used", "refId": "A"}, {"expr": "node_memory_MemTotal_bytes", "legendFormat": "total", "refId": "B"}]},
    {"type": "timeseries", "id": 42, "title": "Disk & Network I/O", "gridPos": {"h": 7, "w": 8, "x": 16, "y": 40}, "fieldConfig": {"defaults": {"unit": "decbytes", "custom": {"lineWidth": 2, "fillOpacity": 10, "showPoints": "never"}}}, "targets": [{"expr": "monero_free_space_bytes", "legendFormat": "free disk", "refId": "A"}, {"expr": "rate(monero_net_total_bytes_in[5m])", "legendFormat": "net in/s", "refId": "B"}, {"expr": "rate(monero_net_total_bytes_out[5m])", "legendFormat": "net out/s", "refId": "C"}]},

    {"type": "row", "title": "Monero Network Trends", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 47}, "collapsed": false, "id": 105, "panels": []},
    {"type": "timeseries", "id": 50, "title": "Network Difficulty", "gridPos": {"h": 7, "w": 8, "x": 0, "y": 48}, "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 10, "gradientMode": "scheme", "showPoints": "never"}}}, "targets": [{"expr": "monero_difficulty", "legendFormat": "difficulty", "refId": "A"}]},
    {"type": "timeseries", "id": 51, "title": "Block Reward (XMR)", "gridPos": {"h": 7, "w": 8, "x": 8, "y": 48}, "fieldConfig": {"defaults": {"unit": "none", "decimals": 6, "custom": {"lineWidth": 2, "fillOpacity": 10, "showPoints": "never"}}}, "targets": [{"expr": "monero_last_block_reward / 1e12", "legendFormat": "reward XMR", "refId": "A"}]},
    {"type": "timeseries", "id": 52, "title": "Txpool Activity", "gridPos": {"h": 7, "w": 8, "x": 16, "y": 48}, "fieldConfig": {"defaults": {"custom": {"lineWidth": 2, "fillOpacity": 10, "showPoints": "never"}}}, "targets": [{"expr": "monero_txpool_txs_total", "legendFormat": "tx count", "refId": "A"}, {"expr": "monero_txpool_bytes_total", "legendFormat": "bytes", "refId": "B"}]}
  ]
}
