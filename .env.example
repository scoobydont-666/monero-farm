# Monero Farm — Environment Configuration
# Copy to .env and populate with your values

# P2Pool Mini Observer Exporter
# XMR miner address for monitoring (required for p2pool_observer_exporter.py)
MINER_ADDRESS=

# Prometheus Exporter Configuration
# EXPORTER_LISTEN_ADDRESS=127.0.0.1
# EXPORTER_LISTEN_PORT=8000

# Exporter Polling and Limits
# EXPORTER_SCRAPE_INTERVAL=60
# EXPORTER_PAYOUT_LIMIT=20
# EXPORTER_LOG_LEVEL=INFO

# P2Pool Configuration
# P2POOL_LISTEN_PORT=3333
# P2POOL_RPC_PORT=18081
# P2POOL_MONEROD_RPC_URL=http://127.0.0.1:18081

# Monitoring and Metrics
# PROMETHEUS_PUSHGATEWAY_URL=http://127.0.0.1:9091
# METRICS_NAMESPACE=monero_farm
